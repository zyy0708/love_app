# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Required)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=couple_diary
DB_USER=postgres
DB_PASSWORD=your_secure_password

# JWT Configuration (Required - must be at least 32 characters in production)
JWT_SECRET=your_very_secure_secret_key_at_least_32_chars

# CORS Configuration (Optional - comma separated in production)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
